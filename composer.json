{
    "name": "symfinity/ux-blocks-extended",
    "description": "Compound UX Twig components with registry-aligned markup and role CSS",
    "license": "MIT",
    "type": "symfony-bundle",
    "homepage": "https://github.com/symfinity/ux-blocks-extended",
    "support": {
        "issues": "https://github.com/symfinity/ux-blocks-extended/issues",
        "source": "https://github.com/symfinity/ux-blocks-extended"
    },
    "authors": [
        {
            "name": "Symfinity",
            "email": "dev@symfinity.net",
            "homepage": "https://symfinity.net/"
        }
    ],
    "keywords": [
        "symfony",
        "symfony-bundle",
        "symfony-ux",
        "twig-components",
        "ux-blocks",
        "design-system",
        "ui-kernel"
    ],
    "require": {
        "php": ">=8.2",
        "symfinity/ux-blocks-core": "^0.1",
        "symfinity/ux-blocks-form": "^0.1",
        "symfony/framework-bundle": "^7.4||^8.0",
        "symfony/twig-bundle": "^7.4||^8.0",
        "symfony/stimulus-bundle": "^2.0|^3.0",
        "symfony/ux-twig-component": "^2.0|^3.0"
    },
    "require-dev": {
        "symfinity/ux-blocks": "^0.1",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^10.5 || ^11.0",
        "symfony/browser-kit": "^7.4||^8.0",
        "symfony/css-selector": "^7.4||^8.0",
        "symfony/http-client": "^7.4||^8.0",
        "symfony/yaml": "^7.4||^8.0",
        "symfinity/ui-kernel": "^0.1"
    },
    "suggest": {
        "symfinity/ux-runtime": "Optional command palette JSON backend (blocks.ext.command-palette)"
    },
    "autoload": {
        "psr-4": {
            "Symfinity\\UxBlocksExtended\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symfinity\\UxBlocksExtended\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml.dist",
        "phpstan": "phpstan analyse --memory-limit=512M"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/serotoninja"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        },
        "symfony": {
            "require": "^7.4||^8.0"
        }
    }
}
