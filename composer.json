{
    "name": "symfinity/ux-blocks-extended",
    "description": "Compound UX Twig components with blocks.ext fragments and composition-language regions",
    "license": "MIT",
    "type": "symfony-bundle",
    "require": {
        "php": ">=8.2",
        "symfinity/ux-blocks-core": "^0.1",
        "symfinity/ux-blocks-form": "^0.1",
        "symfony/framework-bundle": "^7.4||^8.0",
        "symfony/twig-bundle": "^7.4||^8.0",
        "symfony/stimulus-bundle": "^2.0|^3.0",
        "symfony/ux-twig-component": "^2.0|^3.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^10.5 || ^11.0",
        "symfony/browser-kit": "^7.4||^8.0",
        "symfony/css-selector": "^7.4||^8.0",
        "symfony/http-client": "^7.4||^8.0",
        "symfony/yaml": "^7.4||^8.0",
        "symfinity/ui-kernel": "^0.1"
    },
    "suggest": {
        "symfinity/ux-runtime": "Optional command palette JSON backend (blocks.ext.command-palette)"
    },
    "autoload": {
        "psr-4": {
            "Symfinity\\UxBlocksExtended\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symfinity\\UxBlocksExtended\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml.dist",
        "phpstan": "phpstan analyse --memory-limit=512M"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "version": "0.1.0-dev",
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}
