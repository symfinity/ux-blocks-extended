<span
    role="listitem"
    data-ui-role="filter-chip"
    data-symfony--ux-blocks-extended--filter-chips-target="chip"
    {{ attributes }}
>
    {% block content %}{% endblock %}
    <button
        type="button"
        aria-label="Remove"
        data-action="click->symfony--ux-blocks-extended--filter-chips#removeChip"
    >
        ×
    </button>
</span>
