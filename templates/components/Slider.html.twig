<div
    data-ui-role="slider"
    data-ui-fragment="blocks.ext.slider"
    data-controller="symfony--ux-blocks-extended--slider"
    data-symfony--ux-blocks-extended--slider-min-value="0"
    data-symfony--ux-blocks-extended--slider-max-value="100"
    data-symfony--ux-blocks-extended--slider-step-value="1"
    {{ attributes }}
>
    <input
        type="range"
        min="0"
        max="100"
        value="50"
        step="1"
        data-ui-role="slider-input"
        data-symfony--ux-blocks-extended--slider-target="input"
        data-action="input->symfony--ux-blocks-extended--slider#syncValue change->symfony--ux-blocks-extended--slider#syncValue keydown->symfony--ux-blocks-extended--slider#keydown"
    />
    <output data-symfony--ux-blocks-extended--slider-target="output">50</output>
    {% block content %}{% endblock %}
</div>
