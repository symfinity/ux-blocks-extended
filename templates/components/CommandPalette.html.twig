<div
    data-ui-role="command-palette"
    data-ui-fragment="blocks.ext.command-palette"
    data-controller="symfony--ux-blocks-extended--command-palette"
    data-symfony--ux-blocks-extended--command-palette-commands-url-value="{{ commandsUrl }}"
    data-symfony--ux-blocks-extended--command-palette-placeholder-value="{{ placeholder }}"
    data-symfony--ux-blocks-extended--command-palette-open-hotkey-value="{{ openHotkey }}"
    data-symfony--ux-blocks-extended--command-palette-fallback-commands-value="{{ fallbackCommands|json_encode|e('html_attr') }}"
    hidden
    role="dialog"
    aria-modal="true"
    aria-label="Command palette"
    {{ attributes }}
>
    {% block content %}{% endblock %}
</div>
